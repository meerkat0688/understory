# Path to the OKF bundle directory the agent manages
BUNDLE_ROOT=./sample-bundle

# ── Primary model ──────────────────────────────────────────────────────
# Any OpenAI-compatible or Anthropic-compatible API endpoint.
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_API_FORMAT=openai          # "openai" | "anthropic"
LLM_MODEL=                     # model id to request, e.g. "deepseek-chat" or "claude-sonnet-5"

# Optional model allowlist for the chat UI picker (comma-separated).
# For MCP (memory_query / memory_add / memory_update / memory_maintain), on
# "inappropriate content" errors the agent retries the next id in this list
# after LLM_MODEL (only if no files were written yet on mutate).
# LLM_MODEL is always included when set.
#OPENROUTER_MODELS=qwen/qwen3.7-plus,google/gemini-2.5-flash,deepseek/deepseek-v4-flash

# ── Fallback model (optional) ──────────────────────────────────────────
# Used when the primary model fails with a retryable error (timeout, 5xx).
# Leave LLM_FALLBACK_API_BASE_URL empty to disable fallback.
LLM_FALLBACK_API_BASE_URL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_API_FORMAT=openai
LLM_FALLBACK_MODEL=
# LLM_FALLBACK_ALLOW_FOR=query   # optional: restrict to read-only operations

# ── Legacy env vars (still work but deprecated) ─────────────────────────
# Prefer the LLM_API_* vars above. These are mapped automatically.
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
# LLAMACPP_BASE_URL=
# LLAMACPP_API_KEY=
# LOCAL_BASE_URL=
# LOCAL_API_KEY=

# Commit bundle changes to git after each mutation
GIT_AUTOCOMMIT=false

# Chat context policy. Defaults target a model with a 1M-token context window:
# the newest user message is never truncated, large imports omit old chat, and
# normal history gets at most 50K tokens. The server reserves 100K for system
# instructions, tools, output, and estimation error.
#CHAT_CONTEXT_WINDOW_TOKENS=1000000
#CHAT_CONTEXT_SAFETY_TOKENS=100000
#CHAT_HISTORY_MAX_TOKENS=50000
#CHAT_IMPORT_MODE_THRESHOLD_TOKENS=100000

# Only /api/chat accepts this larger JSON body; /mcp remains capped at 4MB.
#CHAT_MAX_REQUEST_BYTES=16777216

# Optional fallback: USD per 1M tokens when the provider does not return a billed cost
# (OpenRouter already sends usage.cost — these are only needed for other providers).
#LLM_INPUT_USD_PER_MTOK=0.32
#LLM_OUTPUT_USD_PER_MTOK=1.28

PORT=3800

# Optional: require "Authorization: Bearer <token>" on /mcp and /api.
# Unset = open (fine for localhost/LAN). Set this before exposing understory anywhere.
#AUTH_TOKEN=
