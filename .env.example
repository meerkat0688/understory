# Path to the OKF bundle directory the agent manages
BUNDLE_ROOT=./sample-bundle

# LLM provider: anthropic | openrouter | local
LLM_PROVIDER=anthropic
# Optional model override (defaults: claude-sonnet-5 / anthropic/claude-sonnet-5 / local-model)
#LLM_MODEL=

ANTHROPIC_API_KEY=
#OPENROUTER_API_KEY=
# For local llama.cpp / any OpenAI-compatible server:
#LOCAL_BASE_URL=http://localhost:8080/v1
#LOCAL_API_KEY=

# Commit bundle changes to git after each mutation
GIT_AUTOCOMMIT=false

PORT=3800
